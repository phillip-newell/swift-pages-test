 implementation of SkiaSharp. To add this to your project, please follow these steps:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Go to the official nuget site for SkiaSharp’s Native Assets ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/www.nuget.org\/packages\/SkiaSharp.NativeAssets.iOS\/"},{"text":").","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click "},{"type":"codeVoice","code":"Download Package"},{"type":"text","text":" on the right hand side."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Unzip the downloaded .nupkg file. This can be done either by renaming the package so that its extension is now .zip instead of .nupkg, and unzipping it using the built in Archive Utility app. The other option is to open the file location (by default it should be at ~\/Downloads) in a terminal and running unzip on the nupkg file."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Go to your Xcode project and select a target.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Select the General tab."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Scroll to ","type":"text"},{"type":"codeVoice","code":"Frameworks, Libraries and Embedded Content"},{"text":" and press the + button.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Select "},{"type":"codeVoice","code":"Add Other..."},{"type":"text","text":" and the "},{"type":"codeVoice","code":"Add Files..."},{"type":"text","text":" options"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Navigate to your extracted skiasharp.nativeassets.ios folder and naviage to "},{"type":"codeVoice","code":"runtimes\/ios\/native\/libSkiaSharp.framework"},{"type":"text","text":" or "},{"type":"codeVoice","code":"runtimes\/iossimulator\/native\/libSkiaSharp.framework"},{"type":"text","text":" depending on if you want the ios or iossimulator framework."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Ensure that "},{"type":"codeVoice","code":"Embed and Sign"},{"type":"text","text":" is selected if it is not already."}],"type":"paragraph"}]}]},{"type":"heading","text":"Quick Start","level":2,"anchor":"Quick-Start"},{"type":"paragraph","inlineContent":[{"text":"Before using any functions within the SDK, please call","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["DymoInit()"]},{"type":"paragraph","inlineContent":[{"text":"This is most naturally called within your app’s init() function.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The most straightfoward way to use the SDK is to load .dymo or .label files (","type":"text"},{"type":"reference","identifier":"https:\/\/www.dymo.com\/support?cfid=user-guide","isActive":true},{"text":" and to print them onto a printer. For example, you can do the following:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import DymoSDK","DymoInit()","let dymoLabel = DymoLabel(xmlOrPath: \"path\/to\/label\", isXML: false)","var selectedPrinter : Printer","let printers = DymoPrinter.GetPrinters()","for p in printers {","    if p.isConnected {","        selectedPrinter = p","    }","}","DymoPrinter.printLabel(label: dymoLabel, printer: p)",""]},{"type":"heading","text":"Sample App","level":2,"anchor":"Sample-App"},{"type":"paragraph","inlineContent":[{"text":"For a more extensive sample, please check out the sample app in this repo, found under Sample\/.","type":"text"}]},{"type":"heading","text":"Permissions","level":2,"anchor":"Permissions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Please include the following usage key in your Info.plist file to allow our SDK to discover and interact with DYMO bluetooth printers"}]},{"type":"codeListing","syntax":null,"code":["<key>NSBluetoothAlwaysUsageDescript